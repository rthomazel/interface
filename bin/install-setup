#! /usr/bin/env bash

set -euo pipefail
shopt -s globstar
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PARTS_DIR="$SCRIPT_DIR/../src/setup-parts"
PROJECTS_DIR="${PROJECTS_DIR:-$(cd "$SCRIPT_DIR/../Desktop" && pwd)}"

#----------------#

declare -A FUNCS

FUNCS[server]="setup_toolchain setup_env_file eleanor_go_download setup_gpg_signing fix_run_permissions"
FUNCS[comms]="setup_toolchain setup_env_file eleanor_go_download setup_gpg_signing"
FUNCS[scheduling]="setup_toolchain setup_env_file eleanor_go_download setup_gpg_signing"
FUNCS["go-common"]="setup_toolchain setup_env_file eleanor_go_download setup_gpg_signing"
FUNCS["member-server"]="setup_toolchain setup_env_file eleanor_go_download setup_gpg_signing"
FUNCS[client]="setup_toolchain setup_env_file eleanor_node_download setup_gpg_signing"
FUNCS["member-client"]="setup_toolchain setup_env_file eleanor_node_download setup_gpg_signing"
FUNCS[go]="setup_toolchain setup_gpg_signing go_download fix_run_permissions"
FUNCS["go-athenahealth"]="setup_toolchain setup_gpg_signing go_download"
FUNCS["jail-mcp"]="setup_toolchain setup_gpg_signing fix_run_permissions"
FUNCS[shared]="setup_toolchain setup_gpg_signing js_install"
FUNCS["compose-files"]="setup_toolchain setup_env_file setup_gpg_signing fix_run_permissions"

#----------------#

assemble() {
	local project=$1
	local funcs="${FUNCS[$project]}"
	local fn

	cat "$PARTS_DIR/header.sh"
	echo
	for fn in $funcs; do
		cat "$PARTS_DIR/fn/${fn}.sh"
		echo
	done
	for fn in $funcs; do
		echo "$fn"
	done
	echo
	echo 'echo "setup complete"'
}

check_or_commit() {
	local project=$1
	local commit=$2
	local target="$PROJECTS_DIR/$project/bin/setup"
	local tmp
	tmp=$(mktemp /tmp/install-setup.XXXXXX)

	assemble "$project" >"$tmp"

	if [[ ! -f "$target" ]]; then
		if [[ "$commit" == "true" ]]; then
			cp "$tmp" "$target"
			chmod +x "$target"
			echo "$project: created"
		else
			echo "$project: bin/setup not found at $target" >&2
			rm "$tmp"
			return 1
		fi
		rm "$tmp"
		return 0
	fi

	if diff -q "$target" "$tmp" >/dev/null 2>&1; then
		echo "$project: up to date"
		rm "$tmp"
		return 0
	fi

	if [[ "$commit" == "true" ]]; then
		cp "$tmp" "$target"
		chmod +x "$target"
		echo "$project: updated"
	else
		echo "$project: drift detected, review: $tmp"
		return 1
	fi

	rm "$tmp"
}

usage() {
	cat <<'EOF'
Usage: install-setup [OPTIONS] [PROJECT...]

Assembles bin/setup for one or more projects from canonical function fragments
and checks for drift against the current file on disk.

Arguments:
  PROJECT    One or more project names to check (default: all projects).
             Known projects: client, comms, compose-files, go, go-athenahealth,
             go-common, jail-mcp, member-client, member-server, scheduling,
             server, shared.

Options:
  --commit   Write the assembled script to <project>/bin/setup and chmod +x.
             Default (no flag): check-only — reports drift and exits non-zero.
  -h, --help Print this help text and exit.
EOF
}

main() {
	local commit=false
	local projects=()
	local exit_code=0
	local arg

	for arg in "$@"; do
		case $arg in
		--commit) commit=true ;;
		-h | --help)
			usage
			return 0
			;;
		*) projects+=("$arg") ;;
		esac
	done

	if [[ ${#projects[@]} -eq 0 ]]; then
		mapfile -t projects < <(printf '%s\n' "${!FUNCS[@]}" | sort)
	fi

	for project in "${projects[@]}"; do
		if [[ -z "${FUNCS[$project]+_}" ]]; then
			echo "error: unknown project '$project'" >&2
			exit_code=1
			continue
		fi
		check_or_commit "$project" "$commit" || exit_code=1
	done

	return $exit_code
}

main "$@"
