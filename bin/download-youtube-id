# downloads youtube videos by id in a few formats
# note: undefined functions are in lib.sh (sourced via BASH_ENV)
# shellcheck disable=SC2155

set -euo pipefail
shopt -s globstar nullglob
trap 'err $LINENO' ERR

### vars and functions ###

readonly initial_working_dir=$(pwd)
readonly vid_id=${1:-}
readonly out_dir="/plex/music/youtube-sets"
# lower = better quality, larger file; 0 is lossless, 51 is worst
readonly crf=26
title=${2:-}
audio_fmt=""
audio_ext=""
video_fmt=""
video_ext=""
tmp_dir=""

check_dependencies() {
  if [ -z "$BASH_ENV" ]; then
    echo "This script uses functions defined externally."
    echo "\$BASH_ENV is used to source dependencies, and is empty."
    echo "If functions are in the environment, please set BASH_ENV to any string."
    exit 1
  fi
}

help() {
  msgln "Usage: $0 <youtube_video_id> <title>"
  msgln
  msgln output will be in "$out_dir"
  msgln note: youtube video id will be appended to title
  exit 0
}

validate_input() {
  if [ ! "$vid_id" ]; then
    help
  fi

  title=${title//-/_}

  if [ ! "$title" ]; then
    help
  fi
}

validate_plex_perms() {
  if ! [[ "$out_dir" =~ ^/plex ]]; then
    debug $LINENO "output not a plex directory, skip"
    return
  fi

  local sudo_timeout=10s
  local not_plex
  not_plex=$(find "$out_dir" -not -user plex -or -not -group plex)

  if [ "$not_plex" ]; then
    log $LINENO sudo required to change ownership of files to plex \(10s\)

    if ! timeout --kill-after="$sudo_timeout" "$sudo_timeout" sudo chown -R plex:plex "$out_dir"; then
      true # ignore timeout here, it's optional
    fi
  fi
}

prepare_temp() {
  # SSD filesystem, avoid bottlenecks
  tmp_dir=$(mktemp -d download-youtube-id-XXXXXX -p "$HOME/.cache")

  log $LINENO using temp "$tmp_dir"
  cd "$tmp_dir"
}

download() {
  local format_id=$1

  if [ ! "$format_id" ]; then
    return
  fi

  # downloading big videos can max out /tmp
  # ejs:github related to automated captcha challenges using deno
  if ! yt-dlp -f "$format_id" "$vid_id" --output "%(title)s-%(release_date)s.%(ext)s" --remote-components ejs:github --paths "temp:/plex/tmp"; then
    fatal "$LINENO" "yt-dlp error"
  fi
}

prompt_audio_format() {
  msgln note: high quality video has no audio, choose audio now
  msgln choose an audio format:

  read -r
  audio_fmt="$REPLY"
  msgln audio extension: \(see column EXT\)

  read -r
  audio_ext="$REPLY"
}

prompt_video_format() {
  msgln Choose a video format:
  msgln 4k: look for mp4 3840x2160
  msgln 2k: look for mp4 2560x1440
  msgln Leave blank to download only audio

  read -r
  video_fmt="$REPLY"

  if [ "$video_fmt" ]; then
    msgln Video extension: \(see column EXT\)

    read -r
    video_ext="$REPLY"
  fi
}

validate_formats() {
  if [ "$audio_fmt" ] && ! [[ "$audio_fmt" =~ ^[0-9]+$ ]]; then
    fatal "$LINENO" "audio format must be a number"
  fi

  if [ "$audio_fmt" ] && [ ! "$audio_ext" ]; then
    fatal "$LINENO" "audio extension required when audio format is set"
  fi

  if [ "$video_fmt" ] && ! [[ "$video_fmt" =~ ^[0-9]+$ ]]; then
    fatal "$LINENO" "video format must be a number"
  fi

  if [ "$video_fmt" ] && [ ! "$video_ext" ]; then
    fatal "$LINENO" "video extension required when video format is set"
  fi

  if [ "$video_fmt" ] && [ ! "$audio_fmt" ]; then
    warn "$LINENO" "video might have no audio"
  fi
}

mux() {
  local name=$1

  if [ ! "$audio_fmt" ] || [ ! "$video_fmt" ]; then
    log "$LINENO" "skip mux: expected audio and video format"
    return
  fi

  # cpu
  # ffmpeg -i ./*."$audio_ext" -i ./*."$video_ext" -crf "$crf" -ac 2 "$name.mp4"

  # gpu using va
  ffmpeg -vaapi_device /dev/dri/renderD128 -i ./*."$audio_ext" -i ./*."$video_ext" \
    -c:v hevc_vaapi -vf format=nv12,hwupload \
    -qp "$crf" -ac 2 "$name.mp4"
  mv "$name.mp4" "$out_dir"
}

convert_MP3() {
  local name=$1

  if [ ! "$audio_fmt" ] || [ "$video_fmt" ]; then
    log "$LINENO" "convert_MP3: skip, this looks like video"
    return
  fi

  local audio_file
  audio_file=$(find . -maxdepth 1 -type f | head -1)

  if [ ! "$audio_file" ]; then
    fatal "$LINENO" "no audio file found"
  fi

  ffmpeg -i "$audio_file" -codec:a libmp3lame -q:a 0 "$name.mp3"
  mv "$name.mp3" "$out_dir"
}

cleanup_tmp() {
  rm -fr "$tmp_dir"
}

### script ###

check_dependencies

if requested_help "$*"; then
  help
fi

validate_input
validate_plex_perms
prepare_temp

yt-dlp "$vid_id" --list-formats --remote-components ejs:github --paths "temp:/plex/tmp"

prompt_audio_format
prompt_video_format

validate_formats

download "$audio_fmt"
download "$video_fmt"

mux "$title-$vid_id"
convert_MP3 "$title-$vid_id"

validate_plex_perms
cleanup_tmp

cd "$initial_working_dir"

info $LINENO ok "$out_dir/$title-$vid_id.mp4"
